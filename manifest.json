{
  "manifest_version": 3,
  "name": "New Tabs Always Open Right of Current",
  "version": "0.1.0",
  "description": "Opens new tabs immediately to the right of the tab you were using.",
  "homepage_url": "https://andkon.dev/new-tabs-right/",
  "permissions": ["webNavigation", "storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "24": "icons/icon-24.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "New Tabs Always Open Right of Current",
    "default_icon": {
      "16": "icons/icon-16.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
